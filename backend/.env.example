# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://rpuser:rppassword@localhost:5432/reward_platform_dev?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_to_a_strong_random_secret_minimum_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_strong_random_secret_minimum_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Cache
CACHE_TTL=300
